          type default_payment_method =
            {
              billing_id: String?,
              card_expiry_month: Float?,
              card_expiry_year: Float?,
              :card_last4_digits => String?,
              type: Stigg::Models::V1::CustomerResponse::Data::DefaultPaymentMethod::type_
            }

          class DefaultPaymentMethod < Stigg::Internal::Type::BaseModel
            attr_accessor billing_id: String?

            attr_accessor card_expiry_month: Float?

            attr_accessor card_expiry_year: Float?

            attr_accessor card_last4_digits: String?

            attr_accessor type: Stigg::Models::V1::CustomerResponse::Data::DefaultPaymentMethod::type_

            def initialize: (
              billing_id: String?,
              card_expiry_month: Float?,
              card_expiry_year: Float?,
              card_last4_digits: String?,
              type: Stigg::Models::V1::CustomerResponse::Data::DefaultPaymentMethod::type_
            ) -> void

            def to_hash: -> {
              billing_id: String?,
              card_expiry_month: Float?,
              card_expiry_year: Float?,
              :card_last4_digits => String?,
              type: Stigg::Models::V1::CustomerResponse::Data::DefaultPaymentMethod::type_
            }

            type type_ = :CARD | :BANK | :CASH_APP

            module Type
              extend Stigg::Internal::Type::Enum

              CARD: :CARD
              BANK: :BANK
              CASH_APP: :CASH_APP

              def self?.values: -> ::Array[Stigg::Models::V1::CustomerResponse::Data::DefaultPaymentMethod::type_]
            end
          end

