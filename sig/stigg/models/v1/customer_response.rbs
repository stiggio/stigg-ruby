module Stigg
  module Models
    module V1
      type customer_response = { data: Stigg::V1::CustomerResponse::Data }

      class CustomerResponse < Stigg::Internal::Type::BaseModel
        attr_accessor data: Stigg::V1::CustomerResponse::Data

        def initialize: (data: Stigg::V1::CustomerResponse::Data) -> void

        def to_hash: -> { data: Stigg::V1::CustomerResponse::Data }

        type data =
          {
            id: String,
            archived_at: Time?,
            created_at: Time,
            updated_at: Time,
            billing_currency: Stigg::Models::V1::CustomerResponse::Data::billing_currency?,
            billing_id: String?,
            coupon_id: String?,
            default_payment_method: Stigg::V1::CustomerResponse::Data::DefaultPaymentMethod?,
            email: String?,
            integrations: ::Array[Stigg::V1::CustomerResponse::Data::Integration],
            metadata: ::Hash[Symbol, String],
            name: String?
          }

        class Data < Stigg::Internal::Type::BaseModel
          attr_accessor id: String

          attr_accessor archived_at: Time?

          attr_accessor created_at: Time

          attr_accessor updated_at: Time

          attr_accessor billing_currency: Stigg::Models::V1::CustomerResponse::Data::billing_currency?

          attr_accessor billing_id: String?

          attr_accessor coupon_id: String?

          attr_accessor default_payment_method: Stigg::V1::CustomerResponse::Data::DefaultPaymentMethod?

          attr_accessor email: String?

          attr_reader integrations: ::Array[Stigg::V1::CustomerResponse::Data::Integration]?

          def integrations=: (
            ::Array[Stigg::V1::CustomerResponse::Data::Integration]
          ) -> ::Array[Stigg::V1::CustomerResponse::Data::Integration]

          attr_reader metadata: ::Hash[Symbol, String]?

          def metadata=: (::Hash[Symbol, String]) -> ::Hash[Symbol, String]

          attr_accessor name: String?

          def initialize: (
            id: String,
            archived_at: Time?,
            created_at: Time,
            updated_at: Time,
            ?billing_currency: Stigg::Models::V1::CustomerResponse::Data::billing_currency?,
            ?billing_id: String?,
            ?coupon_id: String?,
            ?default_payment_method: Stigg::V1::CustomerResponse::Data::DefaultPaymentMethod?,
            ?email: String?,
            ?integrations: ::Array[Stigg::V1::CustomerResponse::Data::Integration],
            ?metadata: ::Hash[Symbol, String],
            ?name: String?
          ) -> void

          def to_hash: -> {
            id: String,
            archived_at: Time?,
