        type billing_cadence = :RECURRING | :ONE_OFF

        module BillingCadence
          extend Stigg::Internal::Type::Enum

          RECURRING: :RECURRING
          ONE_OFF: :ONE_OFF

          def self?.values: -> ::Array[Stigg::Models::V1::PlanListChargesResponse::billing_cadence]
        end

        type billing_model =
          :FLAT_FEE | :MINIMUM_SPEND | :PER_UNIT | :USAGE_BASED | :CREDIT_BASED

        module BillingModel
          extend Stigg::Internal::Type::Enum

          FLAT_FEE: :FLAT_FEE
          MINIMUM_SPEND: :MINIMUM_SPEND
