          CREDIT_BASED: :CREDIT_BASED

          def self?.values: -> ::Array[Stigg::Models::V1::PlanListChargesResponse::billing_model]
        end

        type billing_period = :MONTHLY | :ANNUALLY

        module BillingPeriod
          extend Stigg::Internal::Type::Enum

          MONTHLY: :MONTHLY
          ANNUALLY: :ANNUALLY

          def self?.values: -> ::Array[Stigg::Models::V1::PlanListChargesResponse::billing_period]
        end

