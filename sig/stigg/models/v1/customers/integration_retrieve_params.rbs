module Stigg
  module Models
    module V1
      module Customers
        type integration_retrieve_params =
          { id: String, integration_id: String }
          & Stigg::Internal::Type::request_parameters

        class IntegrationRetrieveParams < Stigg::Internal::Type::BaseModel
          extend Stigg::Internal::Type::RequestParameters::Converter
          include Stigg::Internal::Type::RequestParameters

          attr_accessor id: String

          attr_accessor integration_id: String

          def initialize: (
            id: String,
            integration_id: String,
            ?request_options: Stigg::request_opts
          ) -> void

          def to_hash: -> {
            id: String,
            integration_id: String,
            request_options: Stigg::RequestOptions
          }
        end
      end
    end
  end
end
