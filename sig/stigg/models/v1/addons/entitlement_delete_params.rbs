module Stigg
  module Models
    module V1
      module Addons
        type entitlement_delete_params =
          { addon_id: String, id: String }
          & Stigg::Internal::Type::request_parameters

        class EntitlementDeleteParams < Stigg::Internal::Type::BaseModel
          extend Stigg::Internal::Type::RequestParameters::Converter
          include Stigg::Internal::Type::RequestParameters

          attr_accessor addon_id: String

          attr_accessor id: String

          def initialize: (
            addon_id: String,
            id: String,
            ?request_options: Stigg::request_opts
          ) -> void

          def to_hash: -> {
            addon_id: String,
            id: String,
            request_options: Stigg::RequestOptions
          }
        end
      end
    end
  end
end
