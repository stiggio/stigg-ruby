module Stigg
  module Resources
    class V1
      class Customers
        attr_reader payment_method: Stigg::Resources::V1::Customers::PaymentMethod

        attr_reader promotional_entitlements: Stigg::Resources::V1::Customers::PromotionalEntitlements

        attr_reader integrations: Stigg::Resources::V1::Customers::Integrations

        attr_reader events: Stigg::Resources::V1::Customers::Events

        attr_reader usage: Stigg::Resources::V1::Customers::Usage

        def retrieve: (
          String id,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::CustomerResponse

        def update: (
          String id,
          ?billing_currency: Stigg::Models::V1::CustomerUpdateParams::billing_currency?,
          ?billing_id: String?,
          ?coupon_id: Stigg::Models::V1::CustomerUpdateParams::coupon_id?,
          ?email: String?,
          ?integrations: ::Array[Stigg::V1::CustomerUpdateParams::Integration],
          ?language: String?,
          ?metadata: ::Hash[Symbol, String],
          ?name: String?,
          ?passthrough: Stigg::V1::CustomerUpdateParams::Passthrough,
          ?timezone: String?,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::CustomerResponse

        def list: (
          ?after: String,
          ?before: String,
          ?created_at: Stigg::V1::CustomerListParams::CreatedAt,
          ?email: String,
          ?limit: Integer,
          ?name: String,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::Internal::MyCursorIDPage[Stigg::Models::V1::CustomerListResponse]

        def archive: (
          String id,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::CustomerResponse

        def check_entitlement: (
          String id,
          ?currency_id: String,
          ?feature_id: String,
          ?requested_usage: Integer,
          ?requested_values: ::Array[String],
          ?resource_id: String,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::Models::V1::CustomerCheckEntitlementResponse

        def import: (
          customers: ::Array[Stigg::V1::CustomerImportParams::Customer],
          ?integration_id: String,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::Models::V1::CustomerImportResponse

        def list_resources: (
          String id,
          ?after: String,
          ?before: String,
          ?limit: Integer,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::Internal::MyCursorIDPage[Stigg::Models::V1::CustomerListResourcesResponse]

        def provision: (
          id: String,
          ?billing_currency: Stigg::Models::V1::CustomerProvisionParams::billing_currency?,
          ?billing_id: String?,
          ?coupon_id: Stigg::Models::V1::CustomerProvisionParams::coupon_id?,
          ?default_payment_method: Stigg::V1::CustomerProvisionParams::DefaultPaymentMethod?,
          ?email: String?,
          ?integrations: ::Array[Stigg::V1::CustomerProvisionParams::Integration],
          ?language: String?,
          ?metadata: ::Hash[Symbol, String],
          ?name: String?,
          ?passthrough: Stigg::V1::CustomerProvisionParams::Passthrough,
          ?timezone: String?,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::CustomerResponse

        def retrieve_entitlements: (
          String id,
          ?resource_id: String,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::Models::V1::CustomerRetrieveEntitlementsResponse

        def unarchive: (
          String id,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::CustomerResponse

        def initialize: (client: Stigg::Client) -> void
      end
    end
  end
end
