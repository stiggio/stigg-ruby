module Stigg
  module Resources
    class V1
      class Products
        def archive_product: (
          String id,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::Product

        def create_product: (
          id: String,
          display_name: String,
          ?description: String?,
          ?metadata: ::Hash[Symbol, String]?,
          ?multiple_subscriptions: bool,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::Product

        def duplicate_product: (
          String id,
          target_id: String,
          ?description: String?,
          ?display_name: String,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::Product

        def list_products: (
          ?id: String,
          ?after: String,
          ?before: String,
          ?created_at: Stigg::V1::ProductListProductsParams::CreatedAt,
          ?limit: Integer,
          ?status: ::Array[Stigg::Models::V1::ProductListProductsParams::status],
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::Internal::MyCursorIDPage[Stigg::Models::V1::ProductListProductsResponse]

        def unarchive_product: (
          String id,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::Product

        def update_product: (
          String id,
          ?description: String?,
          ?display_name: String,
          ?metadata: ::Hash[Symbol, String]?,
          ?multiple_subscriptions: bool,
          ?product_settings: Stigg::V1::ProductUpdateProductParams::ProductSettings,
          ?usage_reset_cutoff_rule: Stigg::V1::ProductUpdateProductParams::UsageResetCutoffRule,
          ?x_account_id: String,
          ?x_environment_id: String,
          ?request_options: Stigg::request_opts
        ) -> Stigg::V1::Product

        def initialize: (client: Stigg::Client) -> void
      end
    end
  end
end
